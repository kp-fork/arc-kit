# Project specific
*.log
.arckit-debug/
research/

# Plugin runtime caches — ephemeral, project-scoped, regenerated each session
# (see #494 close: these belong in .gitignore, not ${CLAUDE_PLUGIN_DATA})
.arckit/memory/.last-session
.arckit/memory/.telemetry.jsonl
docs/telemetry.json

# Projects (created by arckit init, not part of the toolkit itself)
projects/

# Vendor proposals (may contain sensitive info)
# Uncomment if you don't want to commit vendor documents
# projects/*/vendors/*/proposal.pdf
# projects/*/vendors/*/proprietary/

# Legacy local directories (no longer generated)
.codex/
.opencode/


# Gemini extension - generated files (static files are checked in)
arckit-gemini/commands/
arckit-gemini/templates/
arckit-gemini/scripts/
arckit-gemini/skills/
arckit-gemini/docs/

# Draft articles (not for version control)
docs/articles/
.tmp*

# Local investor / pitch drafts (kept off the published toolkit; tracked
# docs/INVESTOR-REPORT.md is the single shared artefact)
docs/INVESTOR-DECK.*
docs/INVESTOR-REPORT-hero.*

# Git worktrees
.worktrees/

# Test output
tests/*/output/

# Local experiments — not part of the published toolkit
tools/wardley-lsp/
tests/mermaid-wardley/
.claude/scheduled_tasks.lock

# Ignyte scraper - captured session token (never commit)
docs/auth.txt

# Investor pitch decks - confidential fundraising material.
# arc-kit is a public repo; the decks, scraped investor data (with PII),
# scraper config/tokens, and generator scripts must never be committed.
docs/pitch-decks/
docs/2026-05-20-difc-innovation-licence-setup-guide.pdf

# LinkedIn data export - contains personal PII (connections, messages, phone)
docs/*LinkedInDataExport*

# arckit-consulting/ is a clone of the separate tractorjuice/arckit-fde repo.
# Per project memory, FDE-site changes belong in that repo, not here.
arckit-consulting/
